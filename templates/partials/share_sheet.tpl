<div class="share-sheet-backdrop" id="shareSheetBackdrop">
    <div class="share-sheet">
        <div class="share-sheet-handle"></div>
        <div class="share-sheet-header">
            <span class="share-sheet-title">Share</span>
            <button type="button" class="share-sheet-close" aria-label="Close">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>
        <div class="share-sheet-options">
            <button type="button" class="share-sheet-option" data-share-action="copy">
                <span class="share-sheet-icon">
                    <i class="fa-solid fa-link"></i>
                </span>
                <span class="share-sheet-label">Copy Link</span>
            </button>
            <a class="share-sheet-option" data-share-action="whatsapp" href="#" target="_blank" rel="noopener">
                <span class="share-sheet-icon share-icon-whatsapp">
                    <i class="fa-brands fa-whatsapp"></i>
                </span>
                <span class="share-sheet-label">WhatsApp</span>
            </a>
            <a class="share-sheet-option" data-share-action="facebook" href="#" target="_blank" rel="noopener">
                <span class="share-sheet-icon share-icon-facebook">
                    <i class="fa-brands fa-facebook-f"></i>
                </span>
                <span class="share-sheet-label">Facebook</span>
            </a>
            <a class="share-sheet-option" data-share-action="twitter" href="#" target="_blank" rel="noopener">
                <span class="share-sheet-icon share-icon-twitter">
                    <i class="fa-brands fa-x-twitter"></i>
                </span>
                <span class="share-sheet-label">X (Twitter)</span>
            </a>
            <a class="share-sheet-option" data-share-action="email" href="#">
                <span class="share-sheet-icon">
                    <i class="fa-solid fa-envelope"></i>
                </span>
                <span class="share-sheet-label">Email</span>
            </a>
        </div>
    </div>
</div>
