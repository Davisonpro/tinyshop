{
    "name": "davisonpro/tinyshop",
    "description": "Mobile-first social shop builder",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "slim/slim": "^4.14",
        "slim/psr7": "^1.7",
        "php-di/php-di": "^7.0",
        "php-di/slim-bridge": "^3.4",
        "smarty/smarty": "^5.0",
        "phpmailer/phpmailer": "^7.0",
        "stripe/stripe-php": "^19.3",
        "aws/aws-sdk-php": "^3.369"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "friendsofphp/php-cs-fixer": "^3.75"
    },
    "autoload": {
        "psr-4": {
            "TinyShop\\": "src/"
        }
    },
    "scripts": {
        "analyse": "phpstan analyse",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "cs-fix": "php-cs-fixer fix"
    },
    "config": {
        "optimize-autoloader": true
    }
}
