{
    "name": "davisonpro/tinyshop",
    "description": "Mobile-first social shop builder",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "slim/slim": "^4.14",
        "slim/psr7": "^1.7",
        "php-di/php-di": "^7.0",
        "php-di/slim-bridge": "^3.4",
        "smarty/smarty": "^5.0",
        "phpmailer/phpmailer": "^7.0",
        "stripe/stripe-php": "^19.3"
    },
    "autoload": {
        "psr-4": {
            "TinyShop\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true
    }
}
